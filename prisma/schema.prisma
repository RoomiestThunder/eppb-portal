// EPPB — Единый портал поддержки бизнеса
// Domain model for the universal no-code/low-code service constructor

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------- Identity ----------

enum UserRole {
  CLIENT
  SUPERADMIN // full platform access, not scoped to one organization
  ORG_ADMIN  // manages services/lookups/applications for their own organization only
  AUTHOR     // business-analyst / service author, org-scoped like ORG_ADMIN but constructor-focused
  ANALYST    // read-only across all organizations, cannot mutate anything
}

model User {
  id             String        @id @default(cuid())
  role           UserRole      @default(CLIENT)
  fullName       String
  iin            String? // mock eGov IDP identity number
  bin            String? // for legal entities
  email          String?       @unique
  phone          String?
  organizationId String? // required for ORG_ADMIN/AUTHOR — scopes what they can see/edit; null for SUPERADMIN/ANALYST/CLIENT
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  applications   Application[]
  notifications  Notification[]
  auditLogs      AuditLog[]
}

// ---------- Organizations (Holding + subsidiaries) ----------

model Organization {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  shortName         String
  logoColor         String              @default("#0B5FFF")
  services          Service[]
  analyticsMaterials AnalyticsMaterial[]
  projects          Project[]
  users             User[]
}

// ---------- Reference data (справочники) ----------

model Lookup {
  id        String       @id @default(cuid())
  code      String       @unique // e.g. "regions", "wagon_types"
  name      String
  items     LookupItem[]
}

model LookupItem {
  id       String @id @default(cuid())
  lookupId String
  lookup   Lookup @relation(fields: [lookupId], references: [id], onDelete: Cascade)
  value    String // machine key
  label    String // human label
  labelKk  String?
  order    Int    @default(0)
  meta     String? // JSON blob for extra attrs (e.g. coordinates, rate)
}

// ---------- Universal service constructor ----------

enum ServiceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Service {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  nameKk         String? // казахский перевод — редактируется в конструкторе, опционален (fallback на name)
  shortDescription String
  shortDescriptionKk String?
  fullDescription  String @default("")
  fullDescriptionKk String?
  category       String // e.g. "Лизинг", "Кредитование", "Субсидирование"
  icon           String  @default("Briefcase")
  status         ServiceStatus @default(DRAFT)
  version        Int           @default(1) // bumped on each publish; submitted applications snapshot the schema, so this changing doesn't retroactively affect them
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  complexity     String        @default("simple") // simple | multi-stage
  tags           String        @default("") // comma separated
  stages         ServiceStage[]
  applications   Application[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// A stage = a phase of the client journey, e.g. "Первичная заявка" then "Расширенные данные"
model ServiceStage {
  id            String   @id @default(cuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  order         Int
  title         String
  titleKk       String?
  description   String   @default("")
  descriptionKk String?
  steps         ServiceStep[]
}

// A step = one screen/page of the wizard within a stage
model ServiceStep {
  id            String   @id @default(cuid())
  stageId       String
  stage         ServiceStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  order         Int
  title         String
  titleKk       String?
  description   String   @default("")
  descriptionKk String?
  fields        FormField[]
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  RADIO
  CHECKBOX
  LOOKUP // reference data driven select
  FILE
  CALCULATED
  INFO // static hint/info block, non-input
}

model FormField {
  id            String    @id @default(cuid())
  stepId        String
  step          ServiceStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  order         Int
  key           String // machine name, unique within service
  label         String
  labelKk       String?
  hint          String    @default("")
  hintKk        String?
  type          FieldType
  required      Boolean   @default(false)
  options       String    @default("") // JSON array for SELECT/RADIO static options
  lookupCode    String?   // for LOOKUP type fields
  formula       String?   // for CALCULATED type, JS-like expression referencing other field keys
  visibilityRule String?  // JSON condition tree; null = always visible
  validation    String?   // JSON: {min,max,pattern,minLength,maxLength}
  prefillSource String?   // mock source key e.g. "egov.fullName", "egov.bin"
}

// ---------- Applications (Заявки) ----------

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  ADDITIONAL_INFO_REQUIRED
  APPROVED
  REJECTED
}

model Application {
  id          String   @id @default(cuid())
  number      String   @unique
  idempotencyKey String? @unique // client-generated key; replays of the same submit return the same application
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  serviceVersion Int   @default(1) // Service.version at submission time
  schemaSnapshot String? // serialized stage/step/field tree as it existed at submission time
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  status      ApplicationStatus @default(DRAFT)
  data        String   @default("{}") // JSON of all field values keyed by field key, encrypted at rest (see src/lib/crypto.ts)
  currentStageOrder Int @default(1)
  lastAutosaveAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  history     ApplicationEvent[]
  documents   ApplicationDocument[]
}

// Atomic counters (e.g. application numbering) — avoids the read-then-write race of counting rows.
model Counter {
  id    String @id
  value Int    @default(0)
}

model ApplicationEvent {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String // status_change | comment | integration
  message       String
  createdAt     DateTime @default(now())
}

model ApplicationDocument {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fieldKey      String
  fileName      String
  mockUrl       String   @default("#")
  signedEsign   Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ---------- Analytics reporting module ----------

model AnalyticsMaterial {
  id             String   @id @default(cuid())
  title          String
  description    String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  materialType   String   // portal | report | financial | research | dashboard
  source         String
  period         String
  linkUrl        String
  embeddable     Boolean  @default(false)
  createdAt      DateTime @default(now())
}

// ---------- Interactive project map ----------

model Project {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  region         String
  locality       String
  lat            Float
  lng            Float
  industry       String
  amount         Float
  currency       String  @default("KZT")
  status         String  // planned | financing | active | completed
  periodStart    String
  periodEnd      String
  description    String
}

// ---------- Useful materials / tools for entrepreneurs ----------

model ResourceItem {
  id            String   @id @default(cuid())
  title         String
  titleKk       String?
  description   String
  descriptionKk String?
  category      String   // knowledge_base | template | checklist | calculator | guide
  linkUrl       String   @default("#")
  createdAt     DateTime @default(now())
}

// ---------- Mock integration log (proves integration-readiness) ----------

model IntegrationLog {
  id          String   @id @default(cuid())
  connector   String   // egov_idp | iin_bin_check | esign | bpm_submit | bpm_status | doc_exchange | notify_sms
  direction   String   // request | response
  payload     String   // JSON
  status      String   // ok | error
  createdAt   DateTime @default(now())
}

// ---------- Audit trail for constructor changes ----------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String   // "Service" | "ServiceStage" | "ServiceStep" | "FormField" | "Lookup" | "LookupItem" | ...
  entityId   String
  action     String   // "create" | "update" | "delete" | "publish"
  before     String?  // JSON snapshot before the change (null for create)
  after      String?  // JSON snapshot after the change (null for delete)
  createdAt  DateTime @default(now())
}

// ---------- Async outbox (stand-in for a real message broker) ----------

model OutboxEvent {
  id          String   @id @default(cuid())
  topic       String   // e.g. "bpm.submissions" — mirrors the Kafka topic this would publish to in production
  payload     String   // JSON
  status      String   @default("pending") // pending | processed | failed
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())
  processedAt DateTime?
}
